# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MLP Accelerator – Zybo Z7-10                                           ║
# ║                                                                          ║
# ║  TRACKED (minimum to fully reproduce the project):                       ║
# ║    hardware/rtl/              RTL source (canonical)                     ║
# ║    hardware/firmware/         C application source (canonical)           ║
# ║    hardware/mlp_accel_sys/                                               ║
# ║      ├── *.xpr               Vivado project file                         ║
# ║      ├── *.srcs/             constraints, block design, IP XCI, RTL      ║
# ║      ├── *.hw/*.lpr          hardware link (points to XSA)               ║
# ║      ├── *.hw/*.xsa          exported hardware for Vitis                 ║
# ║      ├── app_component/src/  Vitis C application sources                 ║
# ║      ├── app_component/vitis-comp.json                                   ║
# ║      └── platform/vitis-comp.json                                        ║
# ║    software/                  Python training & inference scripts         ║
# ║    docs/                      project documentation                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
.eggs/
.venv/
venv/
env/
.ipynb_checkpoints/

# ── ML training data ──────────────────────────────────────────────────────────
# MNIST dataset — downloaded at runtime by the training script.
software/data/

# ══════════════════════════════════════════════════════════════════════════════
# VIVADO — generated outputs
#
# Only *.xpr, *.srcs/, and *.hw/{*.lpr,*.xsa} are needed to reopen
# the project. Everything below is regenerated by:
#   Generate Block Design → Run Synthesis → Run Implementation → Generate Bitstream
# ══════════════════════════════════════════════════════════════════════════════

# IP output products and cache
hardware/mlp_accel_sys/*.cache/
hardware/mlp_accel_sys/*.gen/
hardware/mlp_accel_sys/*.ip_user_files/

# Synthesis and implementation runs (can be several GB)
hardware/mlp_accel_sys/*.runs/

# Simulation output
hardware/mlp_accel_sys/*.sim/

# Temporary working files
hardware/mlp_accel_sys/*.tmp/

# Nested project build directory created by mlp_accel_sys.tcl
hardware/mlp_accel_sys/mlp_accel_sys/

# Vivado DFX profiling report — generated at runtime, not needed in repo
hardware/mlp_accel_sys/dfx_runtime.txt

# Hardware export run artefacts — keep only *.lpr and *.xsa
hardware/mlp_accel_sys/*.hw/hw_1/
hardware/mlp_accel_sys/*.hw/sdt/
# XDC copy written during export — canonical source is in *.srcs/constrs_1/
hardware/mlp_accel_sys/*.hw/*.xdc

# Vivado journal and log files
*.jou
*.str
vivado*.backup.jou
vivado*.backup.log
webtalk*.jou
webtalk*.log

# ══════════════════════════════════════════════════════════════════════════════
# VITIS — generated workspace state and build artefacts
#
# Keep: src/*.{c,h,ld,cmake,yaml,txt}, vitis-comp.json, *.xsa
# ══════════════════════════════════════════════════════════════════════════════

# _ide/ holds workspace state — always regenerated when Vitis opens the project
hardware/mlp_accel_sys/_ide/
hardware/mlp_accel_sys/**/_ide/

# Build and export output
hardware/mlp_accel_sys/**/build/
hardware/mlp_accel_sys/**/export/
hardware/mlp_accel_sys/**/logs/

# Clangd / LSP index cache
hardware/mlp_accel_sys/**/.cache/
hardware/mlp_accel_sys/**/.clangd

# compile_commands.json — regenerated by CMake / Vitis build system
hardware/mlp_accel_sys/**/compile_commands.json

# Lopper (SDT / device-tree tooling) workspace
hardware/mlp_accel_sys/.rigel_lopper/
hardware/mlp_accel_sys/**/.rigel_lopper/

# Vitis workspace state files (all regenerated on project open)
hardware/mlp_accel_sys/**/.wsdata
hardware/mlp_accel_sys/**/.peers.ini
hardware/mlp_accel_sys/**/.vitisPlatformRepo.json
hardware/mlp_accel_sys/**/version.ini
hardware/mlp_accel_sys/**/workspace_journal*.py
hardware/mlp_accel_sys/**/*.vitisWorkspace.json

# Vitis platform — all generated files. vitis-comp.json carries machine-specific
# domain paths that break fresh clones; recreate the platform from the XSA instead.
hardware/mlp_accel_sys/platform/vitis-comp.json
hardware/mlp_accel_sys/platform/ps7_cortexa9_0/
hardware/mlp_accel_sys/platform/zynq_fsbl_bsp/
hardware/mlp_accel_sys/platform/zynq_fsbl/
hardware/mlp_accel_sys/platform/.Xil/
hardware/mlp_accel_sys/platform/hw/
hardware/mlp_accel_sys/platform/resources/

# ══════════════════════════════════════════════════════════════════════════════
# REDUNDANT / ARCHIVE
# ══════════════════════════════════════════════════════════════════════════════

# RTL backup folder — canonical copy is in hardware/rtl/
hardware/rtl_bkup/

# Zip archive snapshot — not useful in version control
hardware/mlp_accel_sys_v1.0.zip

# ── docs/ — keep only the proposal PDF, ignore everything else ────────────────
# LaTeX source, Word docs, and build artefacts stay local.
docs/*.tex
docs/*.md
docs/*.docx
docs/*.log
docs/*.synctex.gz
docs/*.aux
docs/*.out
docs/*.toc
docs/*.fls
docs/*.fdb_latexmk

